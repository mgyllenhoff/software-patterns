@startuml
title XML Display & Editing Application\nLayered Architecture — Sequence View

skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam sequenceArrowColor #444444
skinparam sequenceLifeLineBorderColor #444444

skinparam participant {
  BackgroundColor white
  BorderColor #444444
}

skinparam box {
  BorderColor #888888
  FontStyle bold
}

actor User

box "Layer 4: Presentation" #D6EAF8
  participant XMLApplication as App
  participant XMLDisplay      as Disp
end box

box "Layer 3: Application Logic" #D5F5E3
  participant XMLLoader    as Loader
  participant XMLEditor    as Editor
  participant XMLValidator as Val
end box

box "Layer 2: Domain" #FEF9E7
  participant "Domain Model" as DOM
end box

box "Layer 1: Infrastructure" #FDEDEC
  participant XMLTokenizer  as Tok
  participant XMLSerializer as Ser
end box

== Load ==

User -> App    : run(inputFile, outputFile)
App  -> Loader : load(inputFile)
Loader -> Tok  : tokenize file
Loader -> DOM  : build document tree
Loader --> App : Document*
App  -> Disp   : display(document)
Disp -> DOM    : read-only traversal
Disp --> App   : tree printed to stdout

== Edit ==

User -> App    : add / remove / set attribute
App  -> Disp   : getNode(index) : Node*
App  -> Editor : edit operation
Editor -> Val  : validate operation
Editor -> DOM  : mutate document tree
Editor --> App : success / failure
App  -> Disp   : display(document)
Disp -> DOM    : read-only traversal
Disp --> App   : updated tree printed to stdout

== Save ==

User -> App    : save
App  -> Editor : save(document, outputFile)
Editor -> Ser  : serialize document to file
Ser  -> DOM    : read-only traversal
Editor --> App : done

@enduml
